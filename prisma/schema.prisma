generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENTE)
  // Dirección guardada (autocompleta el checkout)
  phone     String?
  address   String?
  district  String?
  city      String?
  reference String?
  mapsLink  String?
  zone      String?
  createdAt DateTime @default(now())
  orders    Order[]
}

enum Role {
  CLIENTE
  ADMIN
}

model Product {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  name        String
  category    String
  tagline     String
  image       String
  imageDetail String
  shortDesc   String
  description String
  highlights  String[]
  badge       String?
  accentClass String
  btnClass    String
  cardBg      String
  protein     String
  netWeight   String
  packaging   String
  active      Boolean       @default(true)
  sizes       ProductSize[]
  createdAt   DateTime      @default(now())
}

model ProductSize {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  sizeKey   String
  label     String
  size      String
  pieces    String
  price     Float
}

model Order {
  id           String      @id @default(cuid())
  user         User        @relation(fields: [userId], references: [id])
  userId       String
  culqiCharge  String
  email        String
  totalCents   Int
  status       OrderStatus @default(PAID)
  // Entrega
  fulfillment  Fulfillment @default(DELIVERY)
  shippingCents Int        @default(0)
  // Datos de envío (nulos si es recojo en tienda)
  customerName String?
  phone        String?
  address      String?
  district     String?
  city         String?
  reference    String?
  mapsLink     String?
  items        OrderItem[]
  createdAt    DateTime    @default(now())
}

enum Fulfillment {
  PICKUP
  DELIVERY
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  productId Int
  sizeId    String
  name      String
  qty       Int
  price     Float
}

enum OrderStatus {
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
